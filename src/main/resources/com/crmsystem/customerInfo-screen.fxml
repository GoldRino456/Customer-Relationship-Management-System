<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.crmsystem.CustomerInfoController">
   <children>
      <Text fx:id="txt_customerheadline" layoutX="14.0" layoutY="40.0" strokeType="OUTSIDE" strokeWidth="0.0" text="New Customer">
         <font>
            <Font size="24.0" />
         </font></Text>
      <TextField fx:id="tf_name" layoutX="88.0" layoutY="112.0" promptText="Customer Name" />
      <TextField fx:id="tf_phone" layoutX="367.0" layoutY="112.0" promptText="Phone Number" />
      <TextField fx:id="tf_address" layoutX="88.0" layoutY="239.0" promptText="Street Address" />
      <TextField fx:id="tf_postalcode" layoutX="367.0" layoutY="239.0" promptText="Postal Code" />
      <ComboBox fx:id="cb_division" layoutX="367.0" layoutY="280.0" prefWidth="150.0" promptText="Divison" />
      <ComboBox fx:id="cb_country" layoutX="88.0" layoutY="280.0" onAction="#onCountrySelection" prefWidth="150.0" promptText="Country" />
      <Text layoutX="14.0" layoutY="98.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Contact Information">
         <font>
            <Font size="14.0" />
         </font>
      </Text>
      <Text layoutX="14.0" layoutY="227.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Home Address">
         <font>
            <Font size="14.0" />
         </font>
      </Text>
      <Button fx:id="btn_save" layoutX="421.0" layoutY="345.0" mnemonicParsing="false" onAction="#onSaveButtonClick" text="Save" />
      <Button fx:id="btn_cancel" layoutX="484.0" layoutY="345.0" mnemonicParsing="false" onAction="#onCancelButtonClick" text="Cancel" />
      <TextField fx:id="tf_custid" editable="false" layoutX="527.0" layoutY="18.0" prefHeight="25.0" prefWidth="47.0" promptText="ID" />
      <Text fx:id="txt_custid" layoutX="448.0" layoutY="35.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Customer ID:" />
      <Text fx:id="txt_custid1" layoutX="321.0" layoutY="129.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Phone:" />
      <Text fx:id="txt_custid11" layoutX="45.0" layoutY="129.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Name:" />
      <Text fx:id="txt_custid111" layoutX="45.0" layoutY="256.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Street:" />
      <Text fx:id="txt_custid1111" layoutX="291.0" layoutY="256.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Postal Code:" />
      <Text fx:id="txt_custid11111" layoutX="314.0" layoutY="297.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Division:" />
      <Text fx:id="txt_custid111111" layoutX="34.0" layoutY="297.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Country:" />
   </children>
</AnchorPane>
