                           <font>
                              <Font size="14.0" />
                           </font>
                        </Text>
                        <Text fx:id="txt_r_totalToday" layoutX="770.0" layoutY="129.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Total Appointments Today:" />
